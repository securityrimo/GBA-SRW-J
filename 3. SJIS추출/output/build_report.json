   "new_off": "0x1240ba6",
   "ptrs": 1
  },
  {
   "off": "0x0008D8B0",
   "jp": "人類は滅亡の危機を逃れ、",
   "ko": "인류는 멸망의 위기를 벗어나、",
   "enc_len": 32,
   "avail": 28,
   "new_off": "0x1240bc6",
   "ptrs": 1
  },
  {
   "off": "0x0008D8CC",
   "jp": "なお混乱の種子をはらみつつも、",
   "ko": "여전히 혼란의 씨앗을 품으면서도、",
   "enc_len": 36,
   "avail": 32,
   "new_off": "0x1240be8",
   "ptrs": 1
  },
  {
   "off": "0x0008D9C8",
   "jp": "現在の月に活動の可能な火山は存在せず、",
   "ko": "현재의 달에 활동가능한 화산은 없으며、",
   "enc_len": 42,
   "avail": 40,
   "new_off": "0x1240c0e",
   "ptrs": 1
  },
  {
   "off": "0x0008DA5C",
   "jp": "そしてまた、少しの時間が流れた・・・",
   "ko": "그리고 또、약간의 시간이 흘렀다・・・",
   "enc_len": 40,
   "avail": 40,
   "new_off": "0x1240c3a",
   "ptrs": 1
  },
  {
   "off": "0x0008DD30",
   "jp": "すべてを狂わせてしまった",
   "ko": "모든걸 혼란하게 만들었어요",
   "enc_len": 28,
   "avail": 28,
   "new_off": "0x1240c64",
   "ptrs": 1
  },
  {
   "off": "0x0008DF1C",
   "jp": "苦い想いが込み上げる。",
   "ko": "생각만해도 치솟는 고통",
   "enc_len": 24,
   "avail": 24,
   "new_off": "0x1240c82",
   "ptrs": 1
  },
  {
   "off": "0x0008DF7C",
   "jp": "あれから一月たつというのに、",
   "ko": "그 사건이 일어난지 한달이 지났는데",
   "enc_len": 38,
   "avail": 32,
   "new_off": "0x1240c9c",
   "ptrs": 1
  },
  {
   "off": "0x0008E008",
   "jp": "あたしが参加していた",
   "ko": "아슈아리・크로이첼사의 병기 개발",
   "enc_len": 34,
   "avail": 24,
   "new_off": "0x1240cc4",
   "ptrs": 1
  },
  {
   "off": "0x0008E020",
   "jp": "火星での実戦経験を買われ、",
   "ko": "화성에서의 실전 경력을 인정받아",
   "enc_len": 34,
   "avail": 28,
   "new_off": "0x1240ce8",
   "ptrs": 1
  },
  {
   "off": "0x0008E03C",
   "jp": "突然の襲撃でドームは壊滅した。",
   "ko": "그들의 습격에 돔은 파괴되었다",
   "enc_len": 32,
   "avail": 32,
   "new_off": "0x1240d0c",
   "ptrs": 1
  },
  {
   "off": "0x0008E118",
   "jp": "スタッフも、訓練生も、設備も、",
   "ko": "스태프、 훈련생、 설비、 데이터、",
   "enc_len": 36,
   "avail": 32,
   "new_off": "0x1240d2e",
   "ptrs": 1
  },
  {
   "off": "0x0008E1A0",
   "jp": "あたしは“彼”の誘いで軍をやめた。",
   "ko": "“그”의 권유에 따라 군대에서 전역했고",
   "enc_len": 42,
   "avail": 36,
   "new_off": "0x1240d54",
   "ptrs": 1
  },
  {
   "off": "0x0008E1F4",
   "jp": "この病室で目を覚まし、",
   "ko": "이 병실에서 눈을 뜨고 생존자가",
   "enc_len": 34,
   "avail": 24,
   "new_off": "0x1240d80",
   "ptrs": 1
  },
  {
   "off": "0x00091738",
   "jp": "防御、援護防御時に必ず発動",
   "ko": "방어、원호방어시 항상 발동",
   "enc_len": 28,
   "avail": 28,
   "new_off": "0x1240da4",
   "ptrs": 1
  },
  {
   "off": "0x000932B8",
   "jp": "弾切れ",
   "ko": "탄약소진",
   "enc_len": 8,
   "avail": 8,
   "new_off": "0x1240dc2",
   "ptrs": 1
  },
  {
   "off": "0x000936FC",
   "jp": "戦闘を起動",
   "ko": "전투를 기동",
   "enc_len": 12,
   "avail": 12,
   "new_off": "0x1240dcc",
   "ptrs": 1
  },
  {
   "off": "0x00093770",
   "jp": "人が抱えるいくつもの問題は",
   "ko": "고질적으로 겪고 있는 여러 문제들은",
   "enc_len": 38,
   "avail": 28,
   "new_off": "0x1240dda",
   "ptrs": 1
  },
  {
   "off": "0x0009378C",
   "jp": "しかし地球環境の悪化と、",
   "ko": "하지만 악화되는 지구 환경과 인류가",
   "enc_len": 38,
   "avail": 28,
   "new_off": "0x1240e02",
   "ptrs": 1
  },
  {
   "off": "0x000937D0",
   "jp": "人類が地球の周辺宙域をこえ",
   "ko": "인류의 생활반경이 지구와 그 주변은",
   "enc_len": 38,
   "avail": 28,
   "new_off": "0x1240e2a",
   "ptrs": 1
  },
  {
   "off": "0x000937EC",
   "jp": "そして火星への植民。",
   "ko": "그리고 화성으로의 이주",
   "enc_len": 24,
   "avail": 24,
   "new_off": "0x1240e52",
   "ptrs": 1
  },
  {
   "off": "0x000938B8",
   "jp": "生み出すことになった。",
   "ko": "변화를 거부하는 사람들이 생겨난다",
   "enc_len": 36,
   "avail": 24,
   "new_off": "0x1240e6c",
   "ptrs": 1
  },
  {
   "off": "0x00093950",
   "jp": "“プラント”の独立を拒みつづけ、",
   "ko": "“플랜트”의 독립을 거부하고 있으며",
   "enc_len": 38,
   "avail": 36,
   "new_off": "0x1240e92",
   "ptrs": 1
  },
  {
   "off": "0x000939CC",
   "jp": "新型コロニー群“プラント”を建設。",
   "ko": "“플랜트”라는 새로운 국가를 건설하지만",
   "enc_len": 42,
   "avail": 36,
   "new_off": "0x1240eba",
   "ptrs": 1
  },
  {
   "off": "0x000939F0",
   "jp": "コーディネイターは、",
   "ko": "우주로 쫓겨난 코디네이터는",
   "enc_len": 28,
   "avail": 24,
   "new_off": "0x1240ee6",
   "ptrs": 1
  },
  {
   "off": "0x00093A90",
   "jp": "また“オルファン”にはいつしか",
   "ko": "또한 “오르판”에는 어느 순간부터",
   "enc_len": 36,
   "avail": 32,
   "new_off": "0x1240f04",
   "ptrs": 1
  },
  {
   "off": "0x00093AB0",
   "jp": "軍の撤退を決定する。",
   "ko": "병력을 철수시키기로 한다",
   "enc_len": 26,
   "avail": 24,
   "new_off": "0x1240f2a",
   "ptrs": 1
  },
  {
   "off": "0x00093AC8",
   "jp": "多くの人々を火星に残したまま、",
   "ko": "화성에 있는 수많은 사람들을 버려두고",
   "enc_len": 40,
   "avail": 32,
   "new_off": "0x1240f46",
   "ptrs": 1
  },
  {
   "off": "0x00093B14",
   "jp": "謎の無人兵器群が火星に侵攻。",
   "ko": "무인기 군대가 화성을 기습했고",
   "enc_len": 32,
   "avail": 32,
   "new_off": "0x1240f70",
   "ptrs": 1
  },
  {
   "off": "0x00093B34",
   "jp": "突如木星方面から飛来した",
   "ko": "목성 방향에서 날아온 수수께끼의",
   "enc_len": 34,
   "avail": 28,
   "new_off": "0x1240f92",
   "ptrs": 1
  },
  {
   "off": "0x00093BE0",
   "jp": "母艦と推測された無数の",
   "ko": "모선으로 추정되는 무수한",
   "enc_len": 26,
   "avail": 24,
   "new_off": "0x1240fb6",
   "ptrs": 1
  },
  {
   "off": "0x00093BF8",
   "jp": "謎の侵略者は、",
   "ko": "의문의 침략자는",
   "enc_len": 16,
   "avail": 16,
   "new_off": "0x1240fd2",
   "ptrs": 1
  },
  {
   "off": "0x00093C08",
   "jp": "“木星トカゲ”と呼ばれることになった",
   "ko": "이후 “목성도마뱀”이라는 명칭이 붙은",
   "enc_len": 40,
   "avail": 40,
   "new_off": "0x1240fe4",
   "ptrs": 1
  },
  {
   "off": "0x00093C30",
   "jp": "活動を開始する者もあらわれた。",
   "ko": "활동을 시작하는 이들도 나타났다",
   "enc_len": 34,
   "avail": 32,
   "new_off": "0x124100e",
   "ptrs": 1
  },
  {
   "off": "0x00093C50",
   "jp": "己の目的を達成するべく",
   "ko": "자신의 목적을 달성하기 위해",
   "enc_len": 30,
   "avail": 24,
   "new_off": "0x1241032",
   "ptrs": 1
  },
  {
   "off": "0x00093C84",
   "jp": "地上での戦闘も頻発し、",
   "ko": "또 지상에서도 전투가 빈번히 발생하고",
